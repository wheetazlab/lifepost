<!DOCTYPE html>
<html lang="{{@site.locale}}">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title page=(t " (Page %)")}}</title>

    {{!-- Fonts: Inter (body) + heading family (swappable) + JetBrains Mono (code). display=swap --}}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Playfair+Display:wght@500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&family=IBM+Plex+Serif:wght@500;600;700&family=Sora:wght@400;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;600&display=swap">

    <link rel="stylesheet" href="{{asset "built/screen.css"}}">
    <link rel="stylesheet" href="{{asset "built/lifepost.css"}}">

    {{#is "home"}}
        {{#if @site.cover_image}}
            <link rel="preload" as="image" href="{{@site.cover_image}}">
        {{/if}}
    {{/is}}

    <style>
        :root {
            --background-color: {{@custom.background_color}};
            --sw-accent-success: {{@custom.accent_success}};
            --sw-accent-danger: {{@custom.accent_danger}};
            --sw-accent-star: {{@custom.accent_star}};
            --sw-on-accent: {{@custom.on_accent_color}};
            --sw-scrim: color-mix(in srgb, {{@custom.header_scrim_color}} 60%, transparent);
            --sw-code-bg: {{@custom.code_background}};
            --sw-code-text: {{@custom.code_text}};
            --sw-code-muted: color-mix(in srgb, {{@custom.code_text}} 55%, {{@custom.code_background}});
            --sw-code-fg-secondary: color-mix(in srgb, {{@custom.code_text}} 80%, {{@custom.code_background}});
        }
    </style>

    <script>
        /* Detect background luminance and set has-dark-text / has-light-text on <html> */
        var accentColor = getComputedStyle(document.documentElement).getPropertyValue('--background-color');
        accentColor = accentColor.trim().slice(1);
        var r = parseInt(accentColor.substr(0, 2), 16);
        var g = parseInt(accentColor.substr(2, 2), 16);
        var b = parseInt(accentColor.substr(4, 2), 16);
        var yiq = ((r * 299) + (g * 587) + (b * 114)) / 1000;
        var textColor = (yiq >= 128) ? 'dark' : 'light';
        document.documentElement.className = `has-${textColor}-text`;

        /* Colour-scheme bootstrap — runs before paint to avoid FOUC flicker */
        (function () {
            var saved = null;
            try { saved = localStorage.getItem('sw-theme'); } catch (e) {}
            var setting = {{#if @custom.color_scheme}}'{{@custom.color_scheme}}'{{else}}'Auto'{{/if}}.toLowerCase();
            var mode = saved || setting;
            if (mode === 'auto') {
                mode = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }
            document.documentElement.setAttribute('data-theme', mode);
            {{!-- expose heading font choice for CSS --}}
            document.documentElement.setAttribute('data-heading-font', '{{#if @custom.heading_font}}{{@custom.heading_font}}{{else}}Fraunces{{/if}}');
        })();
    </script>

    {{ghost_head}}
</head>

<body class="{{body_class}}{{{block "body_class"}}} is-font-sans{{#match @custom.typography "Narrow"}} is-font-narrow{{/match}} theme-lp">
<a class="gh-lp-skip-link" href="#main-content">{{t "Skip to main content"}}</a>
<div class="gh-site">

    {{#is "home"}}
        {{#if @site.cover_image}}
            {{> "components/navbar" navigationLayout=@custom.navigation_layout fullWidth=true}}
        {{else}}
            {{> "components/navbar" navigationLayout=@custom.navigation_layout}}
        {{/if}}
    {{else}}
        {{#if @site.cover_image}}
            {{> "components/navbar" navigationLayout=@custom.navigation_layout fullWidth=true}}
        {{else}}
            {{> "components/navbar" navigationLayout=@custom.navigation_layout}}
        {{/if}}
    {{/is}}

    {{#is "post"}}
        {{#if @custom.show_reading_progress}}
            <div id="gh-reading-progress" aria-hidden="true"><span></span></div>
        {{/if}}
    {{/is}}

    <div id="main-content" tabindex="-1">
        {{{body}}}
    </div>

    {{> components/footer footerText=@custom.footer_text}}

</div>

{{#is "post, page"}}
    {{> "pswp"}}
{{/is}}

<script src="{{asset "built/main.min.js"}}"></script>
<script src="{{asset "built/lifepost.js"}}"></script>

{{ghost_foot}}

</body>

</html>
